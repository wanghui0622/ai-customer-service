        </dependency>
        <dependency>
            <groupId>com.aics</groupId>
            <artifactId>ai-rag</artifactId>
            <version>${project.version}</version>
        </dependency>
        <dependency>
            <groupId>com.aics</groupId>
            <artifactId>ai-memory</artifactId>
            <version>${project.version}</version>
        </dependency>
        <dependency>
            <groupId>com.aics</groupId>
            <artifactId>ai-tools</artifactId>
            <version>${project.version}</version>
        </dependency>
